# ===========================================
# LASBCA Billing System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# EmailJS — Sign up at https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Credo Payment Gateway (eTranzact)
# Sandbox: https://app.credodemo.com → Settings → Developer → API Keys
# Production: https://app.credocentral.com
VITE_CREDO_PUBLIC_KEY=0PUB_your_sandbox_key_here
